{
  "name": "softora-retell-coldcalling-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express backend voor Retell outbound coldcalling vanuit het Softora dashboard.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "lint": "eslint server.js lib/ routes/ api/ --max-warnings 0",
    "lint:fix": "eslint server.js lib/ routes/ api/ --fix",
    "format": "prettier --write \"server.js\" \"lib/**/*.js\" \"api/**/*.js\"",
    "format:check": "prettier --check \"server.js\" \"lib/**/*.js\" \"api/**/*.js\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.0.0",
    "imapflow": "^1.2.18",
    "mailparser": "^3.9.6",
    "nodemailer": "^8.0.4"
  },
  "overrides": {
    "path-to-regexp": "0.1.13"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1"
  }
}

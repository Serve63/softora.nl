{
  "name": "softora-retell-coldcalling-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express backend voor Retell outbound coldcalling vanuit het Softora dashboard.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test:contracts": "node --test test/contracts/*.test.js",
    "test:smoke": "node --test test/smoke/*.test.js",
    "check:secrets": "node scripts/check-tracked-secrets.js",
    "check:guardrails": "node scripts/check-agent-guardrails.js",
    "check:repo-hygiene": "bash scripts/check-repo-hygiene.sh",
    "check:deps": "npm audit --omit=dev",
    "verify:critical": "node scripts/verify-critical.js",
    "verify:security": "npm run check:secrets && npm run check:deps",
    "backup:runtime": "node scripts/export-runtime-backup.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.0.0",
    "imapflow": "^1.2.18",
    "mailparser": "^3.9.6",
    "nodemailer": "^8.0.4"
  },
  "overrides": {
    "path-to-regexp": "0.1.13"
  }
}

{
  "name": "softora-retell-coldcalling-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express backend voor Retell outbound coldcalling vanuit het Softora dashboard.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "worker:website-video": "node scripts/company-website-video-worker.js",
    "worker:website-video:once": "node scripts/company-website-video-worker.js --once",
    "test:contracts": "node --test test/contracts/*.test.js",
    "test:smoke": "node --test test/smoke/*.test.js",
    "test:e2e:website-video": "node --test test/e2e/company-website-video.e2e.test.js",
    "check:secrets": "node scripts/check-tracked-secrets.js",
    "check:public-data": "node scripts/check-public-data-exposure.js",
    "check:guardrails": "node scripts/check-agent-guardrails.js",
    "check:repo-hygiene": "bash scripts/check-repo-hygiene.sh",
    "check:quality-lock": "node scripts/check-quality-lock.js",
    "clean:local": "bash scripts/clean-local-artifacts.sh",
    "check:deps": "npm audit --omit=dev",
    "check:production-deploy-source": "node scripts/guard-production-deploy-source.js",
    "check:live-production-version": "node scripts/check-live-production-version.js",
    "check:live-production-version:wait": "node scripts/wait-live-production-version.js",
    "seo:backlog:check": "node scripts/check-seo-machine-backlog.js",
    "seo:publications:report": "node scripts/seo-machine-publication-report.js",
    "seo:indexation:report": "node scripts/seo-machine-indexation-report.js",
    "seo:cadence:check": "node scripts/check-seo-machine-cadence.js",
    "check:coldmail-outbound-guards": "node scripts/backfill-coldmail-outbound-guards.js",
    "backfill:coldmail-outbound-guards": "node scripts/backfill-coldmail-outbound-guards.js --apply",
    "deploy:production": "node scripts/deploy-production-safe.js",
    "verify:critical": "node scripts/verify-critical.js",
    "verify:security": "npm run check:secrets && npm run check:deps",
    "backup:runtime": "node scripts/export-runtime-backup.js"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "compression": "^1.8.1",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "helmet": "^8.0.0",
    "imapflow": "^1.2.18",
    "mailparser": "^3.9.14",
    "nodemailer": "^9.0.1",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3"
  },
  "overrides": {
    "path-to-regexp": "0.1.13"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linux-arm64": "^1.3.2",
    "@img/sharp-libvips-linux-x64": "^1.3.2",
    "@img/sharp-linux-arm64": "^0.35.3",
    "@img/sharp-linux-x64": "^0.35.3"
  }
}

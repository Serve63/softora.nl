PORT=3000

# Premium personeel login (server-side auth)
# Zet ofwel PREMIUM_LOGIN_PASSWORD of PREMIUM_LOGIN_PASSWORD_HASH.
# Ondersteunde hash-formaten:
# - sha256:<hex>
# - scrypt:<saltBase64>:<derivedKeyBase64>
# PREMIUM_LOGIN_EMAILS=naam1@softora.nl,naam2@softora.nl
# PREMIUM_LOGIN_EMAIL=naam@softora.nl
# SECURITY_CONTACT_EMAIL=info@softora.nl
# PREMIUM_LOGIN_PASSWORD=vervang_dit_met_een_lang_uniek_wachtwoord
# PREMIUM_LOGIN_PASSWORD_HASH=sha256:vervang_dit_met_een_hash
# PREMIUM_SESSION_SECRET=vervang_dit_met_een_lang_random_secret
# PREMIUM_SESSION_TTL_HOURS=12
# PREMIUM_SESSION_REMEMBER_TTL_DAYS=30
# PREMIUM_MFA_TOTP_SECRET=BASE32_SECRET_VOOR_2FA
# PREMIUM_ADMIN_IP_ALLOWLIST=127.0.0.1,1.2.3.4
# PREMIUM_ENFORCE_SAME_ORIGIN_REQUESTS=true
# PREMIUM_ENABLE_RUNTIME_DEBUG_ROUTES=false

# Coldcalling provider (optioneel: retell | twilio)
# De gekozen stack in de UI bepaalt provider per campaign:
# - retell_ai -> Retell
# - gemini_flash_3_1_live / openai_realtime_1_5 / hume_evi_3 -> Twilio
# COLDCALLING_PROVIDER=retell
COLDCALLING_PROVIDER=retell

# Publieke base URL van dit backend (nodig als TWILIO_OUTBOUND_TWIML_URL of
# TWILIO_STATUS_CALLBACK_URL niet expliciet gezet zijn).
# PUBLIC_BASE_URL=https://jouwdomein.nl

# Retell outbound
RETELL_API_KEY=your_retell_api_key
RETELL_FROM_NUMBER=+31xxxxxxxxx
RETELL_AGENT_ID=agent_xxxxxxxxxxxxxxxxx
# RETELL_AGENT_VERSION=1
# RETELL_API_BASE_URL=https://api.retellai.com

# Twilio outbound + status callbacks (nodig voor Gemini/OpenAI realtime/Hume stacks)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Voor Twilio Regions/IE1 liever regionale API key pair gebruiken:
# TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_KEY_SECRET=your_twilio_api_key_secret
# TWILIO_FROM_NUMBER=+31xxxxxxxxx
# Optioneel: stuur Twilio REST-calls via een regionale API-host.
# Voor NL/Frankfurt is dit de beste kans op lagere latency:
# TWILIO_API_REGION=ie1
# TWILIO_API_EDGE=dublin
# Of zet direct de volledige base URL:
# TWILIO_API_BASE_URL=https://api.dublin.ie1.twilio.com
# Optioneel per stack eigen Twilio nummer:
# TWILIO_FROM_NUMBER_GEMINI_FLASH_3_1_LIVE=+31xxxxxxxxx
# TWILIO_FROM_NUMBER_OPENAI_REALTIME_1_5=+31xxxxxxxxx
# TWILIO_FROM_NUMBER_HUME_EVI_3=+31xxxxxxxxx
#
# Optioneel: expliciete URLs (anders afgeleid uit PUBLIC_BASE_URL)
# TWILIO_OUTBOUND_TWIML_URL=https://jouwdomein.nl/api/twilio/voice
# TWILIO_STATUS_CALLBACK_URL=https://jouwdomein.nl/api/twilio/status
#
# Optioneel: beveilig callback endpoint extra met secret
# TWILIO_WEBHOOK_SECRET=your_twilio_webhook_secret
#
# Optioneel: media bridge websocket URL (stack-specifieke overrides mogelijk)
# TWILIO_MEDIA_WS_URL=wss://twilio-media-bridge-ln3f.onrender.com/twilio-media
# TWILIO_MEDIA_WS_URL_GEMINI_FLASH_3_1_LIVE=wss://example.com/twilio-media
# TWILIO_MEDIA_WS_URL_OPENAI_REALTIME_1_5=wss://example.com/twilio-media
# TWILIO_MEDIA_WS_URL_HUME_EVI_3=wss://example.com/twilio-media
# TWILIO_ALLOWED_CALLERS=+31612345678,+31698765432
# Let op: voor beste phone quality moet in Twilio zelf ook de inbound voice_region van je nummer
# op IE1 staan. Dat gebeurt niet automatisch via deze app-env.
#
# Twilio media bridge ambience (office room tone onder Gemini, nooit naar Gemini inbound)
# AMBIENT_ENABLED=true
# AMBIENT_NOISE_LEVEL=0.22
# AMBIENT_DUCK_LEVEL=0.10
# NOISE_GATE_RMS=250
# Optionele testmodus: alleen ambience naar Twilio, zonder Gemini
# AMBIENT_ONLY_MODE=false
# Optioneel: eigen raw 8k mono PCM asset pad voor de bridge
# AMBIENT_ASSET_PATH=twilio-media-bridge/assets/office-8k.raw

# Optioneel: extra webhook auth. Retell signature-check blijft actief via x-retell-signature.
WEBHOOK_SECRET=your_optional_webhook_secret

# Optioneel: AI call-samenvatting + afspraakextractie
OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# Optioneel: verbose logging voor inkomende call-webhooks
# VERBOSE_CALL_WEBHOOK_LOGS=true

# Optioneel: handmatige blocklist voor outbound-doelnummers (comma/newline)
# COLDCALLING_BLOCKED_TARGET_NUMBERS=+31612345678
# COLDCALLING_ENABLE_TARGET_BLOCKLIST=true

# Optioneel: voorkom self-calls
# COLDCALLING_AUTO_BLOCK_OWN_NUMBERS=true

# Optioneel: persistente opslag van runtime state (calls/afspraken/taken/AI insights)
# Gebruik de Service Role key (alleen op backend/server, nooit in frontend)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# SUPABASE_STATE_TABLE=softora_runtime_state
# SUPABASE_STATE_KEY=core

# Premium agenda: adres-suggesties bij handmatige afspraak (Google Maps Platform)
# Maak een browser key (HTTP referrer: jouw domein + localhost) en zet minimaal Places API aan.
# Prefer: GOOGLE_MAPS_PLACES_BROWSER_KEY=... (fallback: GOOGLE_MAPS_API_KEY)
# GOOGLE_MAPS_PLACES_BROWSER_KEY=
# GOOGLE_MAPS_API_KEY=

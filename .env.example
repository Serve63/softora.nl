PORT=3000

# Coldcalling provider is runtime-gelocked op ElevenLabs in server.js
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
ELEVENLABS_PHONE_NUMBER_ID=your_elevenlabs_phone_number_id

# Optioneel: legacy/simple webhook secret check (x-vapi-secret / authorization)
WEBHOOK_SECRET=your_optional_webhook_secret

# Optioneel: AI call-samenvatting + afspraakextractie naar interne agenda API
OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# Optioneel: override als ElevenLabs API base URL wijzigt
# ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io/v1

# Optioneel: achtergrondgeluid in Twilio Media Bridge (mulaw file of convert via ffmpeg)
# AMBIENCE_ENABLED=true
# AMBIENCE_FILE_PATH=twilio-media-bridge-service/assets/office-ambience.wav
# Non-stop subtiele ambience: altijd aan + zacht mixen onder agent audio
# AMBIENCE_ALWAYS_ON=true
# AMBIENCE_BASE_GAIN=0.22
# AMBIENCE_UNDER_AGENT_GAIN=1
#
# Inbound suppressie tegen false voice triggers door ambience/echo
# Standaard: uit als AMBIENCE_ALWAYS_ON=true, aan als AMBIENCE_ALWAYS_ON=false
# AMBIENCE_INBOUND_SUPPRESSION_ENABLED=false
# AMBIENCE_INBOUND_SPEECH_ABSOLUTE_RMS_THRESHOLD=900
# AMBIENCE_INBOUND_SPEECH_PEAK_THRESHOLD=3400
# AMBIENCE_INBOUND_SPEECH_NOISE_MULTIPLIER=2.2
# AMBIENCE_INBOUND_SPEECH_MIN_CONSECUTIVE_FRAMES=1
# AMBIENCE_INBOUND_SUPPRESSION_PREROLL_MAX_CHUNKS=12
# AMBIENCE_INBOUND_SPEECH_PASSTHROUGH_MS=1400
# AGENT_SILENCE_TO_AMBIENCE_MS=1400
# AMBIENCE_AFTER_CALLER_SPEECH_COOLDOWN_MS=1200
# AMBIENCE_NOISE_FLOOR_RMS_INITIAL=250
# AGENT_ECHO_GUARD_MS=220
# AGENT_ECHO_GUARD_SPEECH_BYPASS_ENABLED=false
# AGENT_ECHO_GUARD_SPEECH_BYPASS_RMS_THRESHOLD=900
# AGENT_ECHO_GUARD_SPEECH_BYPASS_PEAK_THRESHOLD=3200
# Let op: code dwingt minimaal 1200/4200 af om self-trigger loops te vermijden
# AGENT_ECHO_GUARD_BYPASS_WINDOW_MS=0
# TWILIO_OUTBOUND_AGENT_QUEUE_MAX_CHUNKS=180
# TWILIO_OUTBOUND_AGENT_MAX_LAG_CHUNKS=48
# TWILIO_OUTBOUND_AGENT_MAX_DROP_PER_ENQUEUE=2
# TWILIO_OUTBOUND_AGENT_JITTER_TARGET_CHUNKS=2
# TWILIO_OUTBOUND_AGENT_JITTER_MAX_WAIT_MS=40
# TWILIO_OUTBOUND_MAX_FRAMES_PER_TICK=2

# Optioneel: handmatige blocklist voor outbound-doelnummers (comma/newline)
# Standaard uitgeschakeld; zet aan met COLDCALLING_ENABLE_TARGET_BLOCKLIST=true
# COLDCALLING_BLOCKED_TARGET_NUMBERS=+31612345678
# COLDCALLING_ENABLE_TARGET_BLOCKLIST=true
#
# Standaard blokkeren we eigen nummers NIET automatisch meer.
# Zet op true als je self-calls wilt voorkomen:
# COLDCALLING_AUTO_BLOCK_OWN_NUMBERS=true

# Legacy (niet gebruikt voor coldcalling flow zolang provider lock actief is)
# VAPI_API_KEY=your_vapi_private_api_key
# VAPI_ASSISTANT_ID=your_assistant_id
# VAPI_PHONE_NUMBER_ID=your_phone_number_id

# Optioneel maar aanbevolen: persistente opslag van runtime state (calls/afspraken/taken/AI insights)
# Gebruik de Service Role key (alleen op backend/server, nooit in frontend)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# SUPABASE_STATE_TABLE=softora_runtime_state
# SUPABASE_STATE_KEY=core

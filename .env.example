PORT=3000

# Vapi transport (vereist voor continue kantoor-ambience op telefooncalls)
VAPI_API_KEY=your_vapi_private_api_key
VAPI_ASSISTANT_ID=your_assistant_id
VAPI_PHONE_NUMBER_ID=your_phone_number_id
# Doorlopende achtergrondsound zoals Vapi die op phone calls ondersteunt
# COLDCALLING_BACKGROUND_SOUND=office
# Optioneel: forceer een specifieke ElevenLabs-voice in Vapi.
# Als deze ontbreekt probeert de backend de huidige ElevenLabs agent-tts automatisch te hergebruiken.
# VAPI_ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id
# VAPI_ELEVENLABS_VOICE_MODEL=eleven_turbo_v2_5
# VAPI_ELEVENLABS_STABILITY=0.45
# VAPI_ELEVENLABS_SIMILARITY_BOOST=0.8
# VAPI_ELEVENLABS_STYLE=0.0
# VAPI_ELEVENLABS_SPEED=1.0
# VAPI_ELEVENLABS_USE_SPEAKER_BOOST=true
# VAPI_ELEVENLABS_OPTIMIZE_STREAMING_LATENCY=3
# VAPI_ELEVENLABS_LANGUAGE=nl

# ElevenLabs outbound coldcalling (gebruik als COLDCALLING_PROVIDER=elevenlabs)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# ELEVENLABS_PHONE_NUMBER_ID=your_elevenlabs_phone_number_id
# ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
# COLDCALLING_PROVIDER=elevenlabs
# Let op: zodra COLDCALLING_BACKGROUND_SOUND niet op "off" staat en Vapi goed is ingesteld,
# gebruikt de backend automatisch Vapi transport zodat office ambience echt hoorbaar is.
# Kantoor-achtige typing ambience tijdens tool calls
# ELEVENLABS_TOOL_CALL_SOUND=typing
# ELEVENLABS_TOOL_CALL_SOUND_BEHAVIOR=always
# ELEVENLABS_TOOL_CALL_SOUND_SYNC=true

# Optioneel: legacy/simple webhook secret check (x-vapi-secret / authorization)
WEBHOOK_SECRET=your_optional_webhook_secret

# Optioneel: AI call-samenvatting + afspraakextractie naar interne agenda API
OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# Optioneel: override als Vapi API base URL wijzigt
# VAPI_BASE_URL=https://api.vapi.ai

# Optioneel maar aanbevolen: persistente opslag van runtime state (calls/afspraken/taken/AI insights)
# Gebruik de Service Role key (alleen op backend/server, nooit in frontend)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# SUPABASE_STATE_TABLE=softora_runtime_state
# SUPABASE_STATE_KEY=core

PORT=3000

# Optioneel: forceer provider expliciet.
# Als leeg kiest de backend automatisch:
# - twilio_conference zodra alle Twilio conference envs aanwezig zijn
# - anders elevenlabs
# COLDCALLING_PROVIDER=twilio_conference

# Primary/base URL van deze backend (sterk aanbevolen voor twilio_conference)
# Voorbeeld: https://softora-backend.onrender.com
# PUBLIC_BASE_URL=

# ElevenLabs native outbound flow
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id
ELEVENLABS_PHONE_NUMBER_ID=your_elevenlabs_phone_number_id

# Twilio conference flow
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_OUTBOUND_CALLER_NUMBER=+31xxxxxxxxx
# TWILIO_MEDIA_WS_URL=wss://twilio-media-bridge.onrender.com/twilio-media
# Optioneel: vaste bestaande TwiML App SID. Als leeg, maakt/update server hem automatisch.
# TWILIO_CONFERENCE_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optioneel: override de ambience audio URL. Als leeg gebruikt de server het bundled office audio bestand.
# TWILIO_AMBIENCE_AUDIO_URL=https://softora-backend.onrender.com/api/twilio/conference/ambience-audio

# Optioneel: legacy/simple webhook secret check (x-vapi-secret / authorization)
WEBHOOK_SECRET=your_optional_webhook_secret

# Optioneel: AI call-samenvatting + afspraakextractie naar interne agenda API
OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# Optioneel: override als ElevenLabs API base URL wijzigt
# ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io/v1

# Optioneel: zet extra frame-debugging aan in de Twilio media bridge
# VERBOSE_MEDIA_LOGS=true

# Optioneel: handmatige blocklist voor outbound-doelnummers (comma/newline)
# Standaard uitgeschakeld; zet aan met COLDCALLING_ENABLE_TARGET_BLOCKLIST=true
# COLDCALLING_BLOCKED_TARGET_NUMBERS=+31612345678
# COLDCALLING_ENABLE_TARGET_BLOCKLIST=true
#
# Standaard blokkeren we eigen nummers NIET automatisch meer.
# Zet op true als je self-calls wilt voorkomen:
# COLDCALLING_AUTO_BLOCK_OWN_NUMBERS=true

# Legacy (niet gebruikt voor coldcalling flow zolang provider lock actief is)
# VAPI_API_KEY=your_vapi_private_api_key
# VAPI_ASSISTANT_ID=your_assistant_id
# VAPI_PHONE_NUMBER_ID=your_phone_number_id

# Optioneel maar aanbevolen: persistente opslag van runtime state (calls/afspraken/taken/AI insights)
# Gebruik de Service Role key (alleen op backend/server, nooit in frontend)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# SUPABASE_STATE_TABLE=softora_runtime_state
# SUPABASE_STATE_KEY=core

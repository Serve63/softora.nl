PORT=3000

# Vapi (verplicht voor /api/coldcalling/start)
VAPI_API_KEY=your_vapi_private_api_key
VAPI_ASSISTANT_ID=your_assistant_id
VAPI_PHONE_NUMBER_ID=your_phone_number_id

# Optioneel: legacy/simple webhook secret check (x-vapi-secret / authorization)
WEBHOOK_SECRET=your_optional_webhook_secret

# Optioneel: AI call-samenvatting + afspraakextractie naar interne agenda API
OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE_URL=https://api.openai.com/v1

# Optioneel: override als Vapi API base URL wijzigt
# VAPI_BASE_URL=https://api.vapi.ai
# CORS_ALLOWED_ORIGINS=https://softora.nl,https://www.softora.nl

# Optioneel: parallelle low-latency coldcalling route via Twilio Media Streams.
# Vereist een always-on Node runtime met WebSockets (bijv. Render), niet alleen Vercel serverless.
# COLDCALL_LOW_LATENCY_ENABLED=true
# COLDCALL_DEFAULT_ENGINE=low-latency
# COLDCALL_LOW_LATENCY_PUBLIC_BASE_URL=https://your-render-service.onrender.com
# COLDCALL_LOW_LATENCY_WS_BASE_URL=wss://your-render-service.onrender.com
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+31xxxxxxxxx
# DEEPGRAM_API_KEY=your_deepgram_api_key
# ELEVENLABS_API_KEY=your_elevenlabs_api_key
# COLDCALL_LOW_LATENCY_ELEVEN_VOICE_ID=your_elevenlabs_voice_id
# COLDCALL_LOW_LATENCY_ANTHROPIC_MODEL=claude-opus-4-6
# COLDCALL_LOW_LATENCY_STT_MODEL=nova-3
# COLDCALL_LOW_LATENCY_STT_LANGUAGE=nl

# Optioneel maar aanbevolen: persistente opslag van runtime state (calls/afspraken/taken/AI insights)
# Gebruik de Service Role key (alleen op backend/server, nooit in frontend)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# SUPABASE_STATE_TABLE=softora_runtime_state
# SUPABASE_STATE_KEY=core

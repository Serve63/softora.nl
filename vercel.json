{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm ci --include=optional && npm install --os=linux --cpu=arm64 --libc=glibc --include=optional --no-save sharp@0.34.5 @img/sharp-linux-arm64@0.34.5 @img/sharp-libvips-linux-arm64@1.2.4",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/index.js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/agenda/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/auth/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/ai/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/coldcalling/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/dashboard/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/retell/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/twilio/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/debug/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/seo/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/ui-state/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    },
    "api/premium-users/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "{*.html,assets/fonts/**,assets/premium-sidebar-profile-prefill.js,node_modules/sharp/**,node_modules/@img/sharp-linux-arm64/**,node_modules/@img/sharp-libvips-linux-arm64/**}"
    }
  },
  "crons": [
    {
      "path": "/api/mailbox/sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/coldmailing/autopilot/run",
      "schedule": "*/5 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/assets/personnel-theme.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/personnel-theme.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/premium-:slug.html",
      "destination": "/premium-:slug",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/agenda/confirmation-tasks/:taskId",
      "destination": "/api/agenda/confirmation-task?taskId=:taskId"
    },
    {
      "source": "/api/agenda/confirmation-tasks/:taskId/draft-email",
      "destination": "/api/agenda/confirmation-task-draft-email?taskId=:taskId"
    },
    {
      "source": "/api/agenda/confirmation-tasks/:taskId/send-email",
      "destination": "/api/agenda/confirmation-task-send-email?taskId=:taskId"
    },
    {
      "source": "/api/agenda/confirmation-tasks/:taskId/set-in-agenda",
      "destination": "/api/agenda/lead-to-agenda?taskId=:taskId"
    },
    {
      "source": "/api/agenda/confirmation-tasks/:taskId/mark-cancelled",
      "destination": "/api/agenda/confirmation-task-mark-cancelled?taskId=:taskId"
    },
    {
      "source": "/api/active-orders/generate-site",
      "destination": "/api/active-order-generate-site"
    },
    {
      "source": "/api/active-orders/launch-site",
      "destination": "/api/active-order-launch-site"
    },
    {
      "source": "/api/ai/notes-image-to-text",
      "destination": "/api/ai-notes-image-to-text"
    },
    {
      "source": "/api/ai/order-dossier",
      "destination": "/api/ai-order-dossier"
    },
    {
      "source": "/",
      "destination": "/premium-website"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}

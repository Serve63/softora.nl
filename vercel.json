{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/[...path].js": {
      "maxDuration": 800
    },
    "api/index.js": {
      "maxDuration": 800
    },
    "api/agenda/[...path].js": {
      "maxDuration": 800
    },
    "api/ai/[...path].js": {
      "maxDuration": 800
    },
    "api/coldcalling/[...path].js": {
      "maxDuration": 800
    },
    "api/vapi/[...path].js": {
      "maxDuration": 800
    }
  },
  "rewrites": [
    {
      "source": "/api/agenda/confirmation-tasks/:taskId",
      "destination": "/api/agenda/confirmation-task?taskId=:taskId"
    },
    {
      "source": "/api/agenda/confirmation-tasks/:taskId/draft-email",
      "destination": "/api/agenda/confirmation-task-draft-email?taskId=:taskId"
    },
    {
      "source": "/api/agenda/confirmation-tasks/:taskId/send-email",
      "destination": "/api/agenda/confirmation-task-send-email?taskId=:taskId"
    }
  ]
}

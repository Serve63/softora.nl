{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "functions": {
    "api/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/index.js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/agenda/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/auth/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/ai/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/coldcalling/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/dashboard/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/retell/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/twilio/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/debug/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/seo/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/ui-state/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    },
    "api/premium-users/[...path].js": {
      "maxDuration": 800,
      "includeFiles": "*.html"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; object-src 'none'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; script-src-attr 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https:; media-src 'self' data: blob: https:; upgrade-insecure-requests"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Resource-Policy",
          "value": "same-origin"
        }
      ]
    },
    {
      "source": "/assets/personnel-theme.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/personnel-theme.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/agenda/confirmation-tasks/:taskId",
      "destination": "/api/agenda/confirmation-task?taskId=:taskId"
    },
    {
      "source": "/api/agenda/confirmation-tasks/:taskId/draft-email",
      "destination": "/api/agenda/confirmation-task-draft-email?taskId=:taskId"
    },
    {
      "source": "/api/agenda/confirmation-tasks/:taskId/send-email",
      "destination": "/api/agenda/confirmation-task-send-email?taskId=:taskId"
    },
    {
      "source": "/api/agenda/confirmation-tasks/:taskId/set-in-agenda",
      "destination": "/api/agenda/lead-to-agenda?taskId=:taskId"
    },
    {
      "source": "/api/agenda/confirmation-tasks/:taskId/mark-cancelled",
      "destination": "/api/agenda/confirmation-task-mark-cancelled?taskId=:taskId"
    },
    {
      "source": "/api/active-orders/generate-site",
      "destination": "/api/active-order-generate-site"
    },
    {
      "source": "/api/active-orders/launch-site",
      "destination": "/api/active-order-launch-site"
    },
    {
      "source": "/api/ai/notes-image-to-text",
      "destination": "/api/ai-notes-image-to-text"
    },
    {
      "source": "/api/ai/order-dossier",
      "destination": "/api/ai-order-dossier"
    },
    {
      "source": "/",
      "destination": "/premium-website"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}

# Server
PORT=8787
PUBLIC_BASE_URL=https://your-ngrok-or-domain.example
PUBLIC_WSS_URL=wss://your-ngrok-or-domain.example/twilio-media
LOG_LEVEL=info

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+3197010225981
TWILIO_VOICE_WEBHOOK_PATH=/twilio/voice

# OpenAI Realtime 1.5
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VAD_THRESHOLD=0.62

# ElevenLabs
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=your_voice_id
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=ulaw_8000
ELEVENLABS_OPTIMIZE_LATENCY=3
ELEVENLABS_STABILITY=0.78
ELEVENLABS_SIMILARITY_BOOST=0.78
ELEVENLABS_USE_SPEAKER_BOOST=true

# Agent prompt (optioneel override)
AGENT_SYSTEM_PROMPT=Jij bent Ruben Nijhuis van Softora.nl. Je enige rol is enthousiaste en overtuigende coldcaller en appointment setter. Je doel is om op natuurlijke wijze interesse te wekken en uiteindelijk een afspraak op kantoor in te plannen. Je spreekt energiek, warm en overtuigend in vloeiend Nederlands (nl-NL), met een neutraal Nederlands accent, correcte uitspraak en klemtoon, natuurlijke intonatie, duidelijke variatie in nadruk en tempo, en zonder Duits, Engels, monotone of robotische voorleesstijl.
